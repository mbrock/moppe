#!/usr/bin/env python3
"""Run a reproducible matrix of end-to-end orogeny iteration benchmarks."""

from __future__ import annotations

import argparse
import csv
import datetime as dt
import io
import platform
from pathlib import Path
import subprocess


def comma_ints(value: str) -> list[int]:
    return [int(part) for part in value.split(",") if part]


def comma_values(value: str) -> list[str]:
    return [part.strip() for part in value.split(",") if part.strip()]


def main() -> None:
    root = Path(__file__).resolve().parent.parent
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("output", nargs="?", default="/tmp/orogeny-benchmark.csv")
    parser.add_argument("--build-dir", default=str(root / "build"))
    parser.add_argument("--resolutions", default="257,513,1025")
    parser.add_argument("--seeds", default="123,731")
    parser.add_argument("--steps", default="4,20")
    parser.add_argument("--routing", default="d8,d-infinity")
    parser.add_argument("--repeats", type=int, default=3)
    parser.add_argument("--skip-build", action="store_true")
    args = parser.parse_args()

    build_dir = Path(args.build_dir).expanduser().resolve()
    executable = build_dir / "terrain-orogeny-benchmark"
    if not args.skip_build:
        subprocess.run(
            ["cmake", "--build", str(build_dir),
             "--target", "terrain-orogeny-benchmark"],
            cwd=root,
            check=True,
        )
    if not executable.is_file():
        raise SystemExit(f"benchmark executable does not exist: {executable}")
    if args.repeats <= 0:
        raise SystemExit("--repeats must be positive")

    commit = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        cwd=root,
        check=True,
        text=True,
        capture_output=True,
    ).stdout.strip()
    started = dt.datetime.now(dt.timezone.utc).isoformat()
    rows: list[dict[str, str]] = []
    for resolution in comma_ints(args.resolutions):
        for seed in comma_ints(args.seeds):
            for steps in comma_ints(args.steps):
                for routing in comma_values(args.routing):
                    result = subprocess.run(
                        [str(executable), str(resolution), str(seed),
                         str(steps), routing, str(args.repeats)],
                        cwd=root,
                        check=True,
                        text=True,
                        capture_output=True,
                    )
                    rows.extend(csv.DictReader(io.StringIO(result.stdout)))

    if not rows:
        raise SystemExit("benchmark matrix produced no rows")
    metadata = {
        "run_started_utc": started,
        "git_commit": commit,
        "host": platform.node(),
        "platform": platform.platform(),
    }
    output = Path(args.output).expanduser().resolve()
    output.parent.mkdir(parents=True, exist_ok=True)
    fields = [*metadata, *rows[0].keys()]
    with output.open("w", newline="") as destination:
        writer = csv.DictWriter(destination, fieldnames=fields)
        writer.writeheader()
        for row in rows:
            writer.writerow(metadata | row)
    print(f"wrote {len(rows)} samples to {output}")


if __name__ == "__main__":
    main()
