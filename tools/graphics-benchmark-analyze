#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
input_arg=${1:?usage: tools/graphics-benchmark-analyze INPUT.csv [OUTPUT_DIR]}
output_arg=${2:-"${input_arg%.csv}-analysis"}
input=$(CDPATH= cd -- "$(dirname -- "$input_arg")" && pwd)/$(basename "$input_arg")
mkdir -p "$output_arg"
output=$(CDPATH= cd -- "$output_arg" && pwd)

case "$input$output" in
  *"'"*)
    echo "paths containing single quotes are not supported" >&2
    exit 2
    ;;
esac

database="$output/graphics-benchmark.duckdb"
rm -f "$database"

(
  cd "$output"
  duckdb "$database" \
    -c "SET VARIABLE input = '$input';" \
    -c ".read $root/tools/graphics_benchmark.sql"
)

duckdb "$database" -c "
  SELECT block,
         round(mean_delta_gpu_ms, 4) AS mean_ms,
         round(median_delta_gpu_ms, 4) AS median_ms,
         round(p95_delta_gpu_ms, 4) AS p95_ms
  FROM block_effects
  ORDER BY mean_delta_gpu_ms DESC;
  SELECT block_a || ' x ' || block_b AS interaction,
         round(mean_interaction_gpu_ms, 4) AS mean_ms
  FROM pairwise_interactions
  ORDER BY abs(mean_interaction_gpu_ms) DESC
  LIMIT 12;
"

{
  printf '# Graphics benchmark analysis\n\n'
  printf '## Frame-budget summary\n\n'
  duckdb -markdown "$database" -c "
    SELECT configurations,
           median_misses_120hz,
           p95_misses_120hz,
           median_misses_60hz,
           round(fastest_median_gpu_ms, 3) AS fastest_median_ms,
           round(slowest_median_gpu_ms, 3) AS slowest_median_ms
    FROM deadline_summary;"
  printf '\n## Average partition-block effects\n\n'
  duckdb -markdown "$database" -c "
    SELECT block,
           round(mean_delta_gpu_ms, 4) AS mean_ms,
           round(median_delta_gpu_ms, 4) AS median_ms,
           round(p05_delta_gpu_ms, 4) AS p05_ms,
           round(p95_delta_gpu_ms, 4) AS p95_ms
    FROM block_effects ORDER BY mean_delta_gpu_ms DESC;"
  printf '\n## Strongest pairwise interactions\n\n'
  duckdb -markdown "$database" -c "
    SELECT block_a || ' x ' || block_b AS interaction,
           round(mean_interaction_gpu_ms, 4) AS mean_ms,
           round(median_interaction_gpu_ms, 4) AS median_ms
    FROM pairwise_interactions
    ORDER BY abs(mean_interaction_gpu_ms) DESC LIMIT 16;"
  printf '\n## Fastest configurations\n\n'
  duckdb -markdown "$database" -c "
    SELECT c.mask,
           coalesce(string_agg(f.name, ', ' ORDER BY f.bit)
             FILTER (WHERE (c.mask & (1 << f.bit)) != 0), '(none)') AS enabled,
           round(c.median_gpu_ms, 3) AS median_ms,
           round(c.p95_gpu_ms, 3) AS p95_ms
    FROM configuration_stats c CROSS JOIN features f
    GROUP BY c.mask, c.median_gpu_ms, c.p95_gpu_ms
    ORDER BY c.median_gpu_ms LIMIT 12;"
  printf '\n## Slowest configurations\n\n'
  duckdb -markdown "$database" -c "
    SELECT c.mask,
           coalesce(string_agg(f.name, ', ' ORDER BY f.bit)
             FILTER (WHERE (c.mask & (1 << f.bit)) != 0), '(none)') AS enabled,
           round(c.median_gpu_ms, 3) AS median_ms,
           round(c.p95_gpu_ms, 3) AS p95_ms
    FROM configuration_stats c CROSS JOIN features f
    GROUP BY c.mask, c.median_gpu_ms, c.p95_gpu_ms
    ORDER BY c.median_gpu_ms DESC LIMIT 12;"
} > "$output/summary.md"

echo "Analysis database: $database"
