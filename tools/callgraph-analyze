#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if ! command -v duckdb >/dev/null 2>&1; then
  echo "DuckDB is required (brew install duckdb)" >&2
  exit 1
fi
if ! command -v uv >/dev/null 2>&1; then
  echo "uv is required" >&2
  exit 1
fi

version=$(duckdb --version | sed -n 's/^v\([0-9][0-9.]*\).*/\1/p')
exec uv run --quiet --with "duckdb==$version" \
  python "$root/tools/callgraph_analyze.py" "$@"
