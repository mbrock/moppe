#!/usr/bin/env bash

set -euo pipefail

root="$(cd "$(dirname "$0")/.." && pwd)"
device="${MOPPE_TVOS_DEVICE:-Living Room}"
team="${MOPPE_TVOS_TEAM:-AA8RNDKMB9}"
configuration="${MOPPE_TVOS_CONFIGURATION:-Release}"
build_dir="${MOPPE_TVOS_BUILD_DIR:-$root/build-tvos-device}"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<EOF
Usage: make tv

Builds, installs, and launches Moppe on a paired Apple TV.

Environment overrides:
  MOPPE_TVOS_DEVICE         Device name or identifier (default: $device)
  MOPPE_TVOS_TEAM           Apple development team (default: $team)
  MOPPE_TVOS_CONFIGURATION  Xcode configuration (default: $configuration)
  MOPPE_TVOS_BUILD_DIR      Physical-device build directory
EOF
  exit 0
fi

echo "Checking $device..."
device_id="$device"
if ! xcrun devicectl device info details \
  --device "$device_id" >/dev/null 2>&1; then
  device_id="$({ xcrun devicectl list devices 2>/dev/null || true; } | awk \
    -v name="$device" 'index($0, name) == 1 {
      for (i = 1; i <= NF; ++i)
        if (length($i) == 36 && substr($i, 9, 1) == "-" &&
            substr($i, 14, 1) == "-" && substr($i, 19, 1) == "-" &&
            substr($i, 24, 1) == "-") {
          print $i
          exit
        }
    }')"
fi
if [[ -z "$device_id" ]] || ! xcrun devicectl device info details \
  --device "$device_id" >/dev/null 2>&1; then
  echo "error: $device is not paired and available to Xcode." >&2
  echo "Open Settings > Remotes and Devices > Remote App and Devices" >&2
  echo "on Apple TV, then pair it in Xcode's Device Hub." >&2
  exit 1
fi
device_udid="$(xcrun devicectl device info details --device "$device_id" | \
  awk '/udid:/ { print $NF; exit }')"
if [[ -z "$device_udid" ]]; then
  echo "error: could not determine Xcode's identifier for $device." >&2
  exit 1
fi

echo "Configuring the physical-device build..."
cmake -S "$root" -B "$build_dir" -G Xcode \
  -DCMAKE_SYSTEM_NAME=tvOS \
  -DCMAKE_OSX_SYSROOT=appletvos \
  -DCMAKE_OSX_ARCHITECTURES=arm64

echo "Building and signing Moppe for $device..."
xcodebuild -quiet \
  -allowProvisioningDeviceRegistration \
  -allowProvisioningUpdates \
  -project "$build_dir/moppe.xcodeproj" \
  -scheme moppe-tvos \
  -configuration "$configuration" \
  -destination "platform=tvOS,id=$device_udid" \
  CODE_SIGN_STYLE=Automatic \
  DEVELOPMENT_TEAM="$team" \
  build

app="$build_dir/$configuration-appletvos/Moppe.app"
if [[ ! -d "$app" ]]; then
  echo "error: expected app was not produced at $app" >&2
  exit 1
fi

echo "Installing Moppe on $device..."
xcrun devicectl device install app --device "$device_id" "$app"

echo "Launching Moppe..."
xcrun devicectl device process launch \
  --device "$device_id" se.brockman.moppe.tvos

echo "Moppe is installed and running on $device."
